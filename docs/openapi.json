{
    "openapi": "3.0.0",
    "info": {
        "title": "Vibe Sport API",
        "description": "Sports Facility Booking API - MVP",
        "version": "1.0",
        "contact": {}
    },
    "tags": [
        {
            "name": "Auth",
            "description": ""
        },
        {
            "name": "Venues",
            "description": ""
        },
        {
            "name": "Availability",
            "description": ""
        },
        {
            "name": "Bookings",
            "description": ""
        },
        {
            "name": "My Bookings",
            "description": ""
        },
        {
            "name": "Owner",
            "description": ""
        }
    ],
    "servers": [],
    "components": {
        "securitySchemes": {
            "bearer": {
                "scheme": "bearer",
                "bearerFormat": "JWT",
                "type": "http"
            }
        },
        "schemas": {
            "LoginDto": {
                "type": "object",
                "properties": {
                    "phoneOrEmail": {
                        "type": "string",
                        "example": "user@example.com",
                        "description": "Phone or email"
                    },
                    "otpOrPassword": {
                        "type": "string",
                        "example": "password123",
                        "description": "Password or OTP"
                    }
                },
                "required": [
                    "phoneOrEmail",
                    "otpOrPassword"
                ]
            },
            "UserResponseDto": {
                "type": "object",
                "properties": {
                    "userId": {
                        "type": "string",
                        "example": "uuid"
                    },
                    "role": {
                        "type": "string",
                        "example": "CUSTOMER"
                    }
                },
                "required": [
                    "userId",
                    "role"
                ]
            },
            "LoginResponseDto": {
                "type": "object",
                "properties": {
                    "token": {
                        "type": "string",
                        "example": "jwt.token.here"
                    },
                    "user": {
                        "$ref": "#/components/schemas/UserResponseDto"
                    }
                },
                "required": [
                    "token",
                    "user"
                ]
            },
            "SearchVenuesQueryDto": {
                "type": "object",
                "properties": {
                    "lat": {
                        "type": "number",
                        "example": 10.762622,
                        "description": "Latitude"
                    },
                    "lng": {
                        "type": "number",
                        "example": 106.660172,
                        "description": "Longitude"
                    },
                    "radiusKm": {
                        "type": "number",
                        "example": 10,
                        "description": "Radius in km",
                        "minimum": 0
                    },
                    "sportType": {
                        "type": "string",
                        "example": "FOOTBALL",
                        "description": "Sport type"
                    },
                    "q": {
                        "type": "string",
                        "example": "sân",
                        "description": "Search query"
                    },
                    "page": {
                        "type": "number",
                        "example": 0,
                        "description": "Page number",
                        "minimum": 0
                    },
                    "size": {
                        "type": "number",
                        "example": 10,
                        "description": "Page size",
                        "minimum": 1
                    }
                }
            },
            "VenueListItemDto": {
                "type": "object",
                "properties": {
                    "venueId": {
                        "type": "string",
                        "example": "uuid"
                    },
                    "name": {
                        "type": "string",
                        "example": "Sân ABC"
                    },
                    "address": {
                        "type": "string",
                        "example": "123 Street, District"
                    },
                    "lat": {
                        "type": "number",
                        "example": 10.762622
                    },
                    "lng": {
                        "type": "number",
                        "example": 106.660172
                    },
                    "distanceKm": {
                        "type": "number",
                        "example": 2.4
                    },
                    "sportTypes": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "example": [
                            "FOOTBALL"
                        ]
                    }
                },
                "required": [
                    "venueId",
                    "name",
                    "address",
                    "lat",
                    "lng",
                    "sportTypes"
                ]
            },
            "VenueListResponseDto": {
                "type": "object",
                "properties": {
                    "items": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/VenueListItemDto"
                        }
                    },
                    "page": {
                        "type": "number",
                        "example": 0
                    },
                    "size": {
                        "type": "number",
                        "example": 10
                    },
                    "total": {
                        "type": "number",
                        "example": 1
                    }
                },
                "required": [
                    "items",
                    "page",
                    "size",
                    "total"
                ]
            },
            "CourtItemDto": {
                "type": "object",
                "properties": {
                    "courtId": {
                        "type": "string",
                        "example": "uuid"
                    },
                    "name": {
                        "type": "string",
                        "example": "Sân 1"
                    },
                    "sportType": {
                        "type": "string",
                        "example": "FOOTBALL"
                    }
                },
                "required": [
                    "courtId",
                    "name",
                    "sportType"
                ]
            },
            "VenueDetailResponseDto": {
                "type": "object",
                "properties": {
                    "venueId": {
                        "type": "string",
                        "example": "uuid"
                    },
                    "name": {
                        "type": "string",
                        "example": "Sân ABC"
                    },
                    "address": {
                        "type": "string",
                        "example": "123 Street, District"
                    },
                    "lat": {
                        "type": "number",
                        "example": 10.762622
                    },
                    "lng": {
                        "type": "number",
                        "example": 106.660172
                    },
                    "courts": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/CourtItemDto"
                        }
                    }
                },
                "required": [
                    "venueId",
                    "name",
                    "address",
                    "lat",
                    "lng",
                    "courts"
                ]
            },
            "GetAvailabilityQueryDto": {
                "type": "object",
                "properties": {
                    "date": {
                        "type": "string",
                        "example": "2026-01-10",
                        "description": "Date (YYYY-MM-DD)"
                    }
                },
                "required": [
                    "date"
                ]
            },
            "SlotDto": {
                "type": "object",
                "properties": {
                    "startTime": {
                        "type": "string",
                        "example": "2026-01-10T18:00:00Z"
                    },
                    "endTime": {
                        "type": "string",
                        "example": "2026-01-10T19:00:00Z"
                    },
                    "status": {
                        "type": "string",
                        "enum": [
                            "AVAILABLE",
                            "UNAVAILABLE"
                        ],
                        "example": "AVAILABLE"
                    },
                    "price": {
                        "type": "number",
                        "example": 200000
                    }
                },
                "required": [
                    "startTime",
                    "endTime",
                    "status"
                ]
            },
            "AvailabilityResponseDto": {
                "type": "object",
                "properties": {
                    "courtId": {
                        "type": "string",
                        "example": "uuid"
                    },
                    "date": {
                        "type": "string",
                        "example": "2026-01-10"
                    },
                    "slots": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/SlotDto"
                        }
                    }
                },
                "required": [
                    "courtId",
                    "date",
                    "slots"
                ]
            },
            "CreateHoldDto": {
                "type": "object",
                "properties": {
                    "courtId": {
                        "type": "string",
                        "example": "uuid",
                        "description": "Court ID"
                    },
                    "startTime": {
                        "type": "string",
                        "example": "2026-01-10T18:00:00Z",
                        "description": "Start time (ISO 8601)"
                    },
                    "endTime": {
                        "type": "string",
                        "example": "2026-01-10T19:00:00Z",
                        "description": "End time (ISO 8601)"
                    }
                },
                "required": [
                    "courtId",
                    "startTime",
                    "endTime"
                ]
            },
            "HoldResponseDto": {
                "type": "object",
                "properties": {
                    "bookingId": {
                        "type": "string",
                        "example": "uuid"
                    },
                    "status": {
                        "type": "string",
                        "enum": [
                            "HOLD"
                        ],
                        "example": "HOLD"
                    },
                    "holdExpiresAt": {
                        "type": "string",
                        "example": "2026-01-10T17:05:00Z"
                    },
                    "totalPrice": {
                        "type": "number",
                        "example": 200000
                    }
                },
                "required": [
                    "bookingId",
                    "status",
                    "holdExpiresAt",
                    "totalPrice"
                ]
            },
            "ConfirmBookingDto": {
                "type": "object",
                "properties": {
                    "note": {
                        "type": "string",
                        "example": "Special request",
                        "description": "Optional note"
                    }
                }
            },
            "ConfirmResponseDto": {
                "type": "object",
                "properties": {
                    "bookingId": {
                        "type": "string",
                        "example": "uuid"
                    },
                    "status": {
                        "type": "string",
                        "enum": [
                            "CONFIRMED"
                        ],
                        "example": "CONFIRMED"
                    },
                    "courtId": {
                        "type": "string",
                        "example": "uuid"
                    },
                    "startTime": {
                        "type": "string",
                        "example": "2026-01-10T18:00:00Z"
                    },
                    "endTime": {
                        "type": "string",
                        "example": "2026-01-10T19:00:00Z"
                    },
                    "totalPrice": {
                        "type": "number",
                        "example": 200000
                    }
                },
                "required": [
                    "bookingId",
                    "status",
                    "courtId",
                    "startTime",
                    "endTime",
                    "totalPrice"
                ]
            },
            "CancelBookingDto": {
                "type": "object",
                "properties": {
                    "reason": {
                        "type": "string",
                        "example": "Cannot attend",
                        "description": "Cancellation reason"
                    }
                },
                "required": [
                    "reason"
                ]
            },
            "CancelResponseDto": {
                "type": "object",
                "properties": {
                    "bookingId": {
                        "type": "string",
                        "example": "uuid"
                    },
                    "status": {
                        "type": "string",
                        "enum": [
                            "CANCELLED_BY_USER",
                            "CANCELLED_BY_OWNER"
                        ],
                        "example": "CANCELLED_BY_USER"
                    }
                },
                "required": [
                    "bookingId",
                    "status"
                ]
            },
            "GetMyBookingsQueryDto": {
                "type": "object",
                "properties": {
                    "status": {
                        "type": "string",
                        "enum": [
                            "PENDING",
                            "CONFIRMED",
                            "CANCELLED",
                            "COMPLETED"
                        ],
                        "description": "Filter by status"
                    },
                    "from": {
                        "type": "string",
                        "example": "2026-01-01",
                        "description": "From date"
                    },
                    "to": {
                        "type": "string",
                        "example": "2026-01-31",
                        "description": "To date"
                    },
                    "page": {
                        "type": "number",
                        "example": 0,
                        "description": "Page number (0-based)",
                        "minimum": 0
                    },
                    "size": {
                        "type": "number",
                        "example": 10,
                        "description": "Page size",
                        "minimum": 1
                    }
                }
            },
            "BookingItemDto": {
                "type": "object",
                "properties": {
                    "bookingId": {
                        "type": "string",
                        "example": "uuid"
                    },
                    "status": {
                        "type": "string",
                        "enum": [
                            "CONFIRMED"
                        ],
                        "example": "CONFIRMED"
                    },
                    "courtId": {
                        "type": "string",
                        "example": "uuid"
                    },
                    "startTime": {
                        "type": "string",
                        "example": "2026-01-10T18:00:00Z"
                    },
                    "endTime": {
                        "type": "string",
                        "example": "2026-01-10T19:00:00Z"
                    },
                    "totalPrice": {
                        "type": "number",
                        "example": 200000
                    },
                    "createdAt": {
                        "type": "string",
                        "example": "2026-01-10T10:00:00Z"
                    }
                },
                "required": [
                    "bookingId",
                    "status",
                    "courtId",
                    "startTime",
                    "endTime"
                ]
            },
            "BookingsListResponseDto": {
                "type": "object",
                "properties": {
                    "items": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/BookingItemDto"
                        }
                    },
                    "page": {
                        "type": "number",
                        "example": 0
                    },
                    "size": {
                        "type": "number",
                        "example": 10
                    },
                    "total": {
                        "type": "number",
                        "example": 1
                    }
                },
                "required": [
                    "items",
                    "page",
                    "size",
                    "total"
                ]
            },
            "VenueAnalyticsResponseDto": {
                "type": "object",
                "properties": {
                    "totalRevenue": {
                        "type": "number",
                        "example": 1500000
                    },
                    "totalBookings": {
                        "type": "number",
                        "example": 25
                    },
                    "completedBookings": {
                        "type": "number",
                        "example": 20
                    },
                    "cancelledBookings": {
                        "type": "number",
                        "example": 5
                    }
                },
                "required": [
                    "totalRevenue",
                    "totalBookings",
                    "completedBookings",
                    "cancelledBookings"
                ]
            },
            "VenueAnalyticsQueryDto": {
                "type": "object",
                "properties": {
                    "from": {
                        "type": "string",
                        "example": "2026-01-01"
                    },
                    "to": {
                        "type": "string",
                        "example": "2026-01-31"
                    }
                },
                "required": [
                    "from",
                    "to"
                ]
            },
            "GetOwnerBookingsQueryDto": {
                "type": "object",
                "properties": {
                    "from": {
                        "type": "string",
                        "example": "2026-01-01"
                    },
                    "to": {
                        "type": "string",
                        "example": "2026-01-31"
                    },
                    "courtId": {
                        "type": "string",
                        "example": "uuid"
                    },
                    "status": {
                        "type": "string"
                    },
                    "page": {
                        "type": "number",
                        "example": 0
                    },
                    "size": {
                        "type": "number",
                        "example": 10
                    }
                }
            },
            "OwnerBookingItemDto": {
                "type": "object",
                "properties": {
                    "bookingId": {
                        "type": "string",
                        "example": "uuid"
                    },
                    "status": {
                        "type": "string"
                    },
                    "courtId": {
                        "type": "string",
                        "example": "uuid"
                    },
                    "startTime": {
                        "type": "string",
                        "example": "2026-01-10T18:00:00Z"
                    },
                    "endTime": {
                        "type": "string",
                        "example": "2026-01-10T19:00:00Z"
                    },
                    "customer": {
                        "$ref": "#/components/schemas/CustomerInfoDto"
                    }
                },
                "required": [
                    "bookingId",
                    "status",
                    "courtId",
                    "startTime",
                    "endTime",
                    "customer"
                ]
            },
            "CustomerInfoDto": {
                "type": "object",
                "properties": {
                    "userId": {
                        "type": "string",
                        "example": "uuid"
                    },
                    "fullName": {
                        "type": "string",
                        "example": "John Doe"
                    },
                    "phone": {
                        "type": "string",
                        "example": "0912345678"
                    }
                },
                "required": [
                    "userId",
                    "fullName"
                ]
            },
            "OwnerBookingsListResponseDto": {
                "type": "object",
                "properties": {
                    "items": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/OwnerBookingItemDto"
                        }
                    },
                    "page": {
                        "type": "number",
                        "example": 0
                    },
                    "size": {
                        "type": "number",
                        "example": 10
                    },
                    "total": {
                        "type": "number",
                        "example": 1
                    }
                },
                "required": [
                    "items",
                    "page",
                    "size",
                    "total"
                ]
            },
            "OwnerCancelBookingDto": {
                "type": "object",
                "properties": {
                    "reason": {
                        "type": "string",
                        "example": "Court maintenance"
                    }
                },
                "required": [
                    "reason"
                ]
            }
        }
    },
    "paths": {
        "/auth/login": {
            "post": {
                "operationId": "AuthController_login",
                "summary": "Login",
                "parameters": [],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/LoginDto"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/LoginResponseDto"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Invalid credentials"
                    }
                },
                "tags": [
                    "Auth"
                ]
            }
        },
        "/venues": {
            "get": {
                "operationId": "VenuesController_searchVenues",
                "summary": "Search venues",
                "parameters": [
                    {
                        "name": "lat",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "number",
                            "example": 10.762622
                        }
                    },
                    {
                        "name": "lng",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "number",
                            "example": 106.660172
                        }
                    },
                    {
                        "name": "radiusKm",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "number",
                            "example": 10,
                            "minimum": 0
                        }
                    },
                    {
                        "name": "sportType",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "example": "FOOTBALL"
                        }
                    },
                    {
                        "name": "q",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "example": "sân"
                        }
                    },
                    {
                        "name": "page",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "number",
                            "example": 0,
                            "minimum": 0
                        }
                    },
                    {
                        "name": "size",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "number",
                            "example": 10,
                            "minimum": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/VenueListResponseDto"
                                }
                            }
                        }
                    }
                },
                "tags": [
                    "Venues"
                ]
            }
        },
        "/venues/{venueId}": {
            "get": {
                "operationId": "VenuesController_getVenueDetail",
                "summary": "Get venue detail with courts",
                "parameters": [
                    {
                        "name": "venueId",
                        "required": true,
                        "in": "path",
                        "schema": {
                            "format": "uuid",
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/VenueDetailResponseDto"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Venue not found"
                    }
                },
                "tags": [
                    "Venues"
                ]
            }
        },
        "/courts/{courtId}/availability": {
            "get": {
                "operationId": "AvailabilityController_getAvailability",
                "summary": "Get court availability for a specific date",
                "parameters": [
                    {
                        "name": "courtId",
                        "required": true,
                        "in": "path",
                        "schema": {
                            "format": "uuid",
                            "type": "string"
                        }
                    },
                    {
                        "name": "date",
                        "required": true,
                        "in": "query",
                        "schema": {
                            "type": "string",
                            "example": "2026-01-10"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/AvailabilityResponseDto"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Court not found"
                    }
                },
                "tags": [
                    "Availability"
                ]
            }
        },
        "/bookings/hold": {
            "post": {
                "operationId": "BookingsController_createHold",
                "summary": "Create a hold on a slot",
                "parameters": [],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/CreateHoldDto"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HoldResponseDto"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Outside operating hours or invalid time"
                    },
                    "409": {
                        "description": "Slot already held/confirmed"
                    }
                },
                "tags": [
                    "Bookings"
                ],
                "security": [
                    {
                        "bearer": []
                    }
                ]
            }
        },
        "/bookings/{bookingId}/confirm": {
            "post": {
                "operationId": "BookingsController_confirmBooking",
                "summary": "Confirm a held booking",
                "parameters": [
                    {
                        "name": "bookingId",
                        "required": true,
                        "in": "path",
                        "schema": {
                            "format": "uuid",
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ConfirmBookingDto"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ConfirmResponseDto"
                                }
                            }
                        }
                    },
                    "409": {
                        "description": "Slot already confirmed by others"
                    },
                    "410": {
                        "description": "Hold expired"
                    }
                },
                "tags": [
                    "Bookings"
                ],
                "security": [
                    {
                        "bearer": []
                    }
                ]
            }
        },
        "/bookings/{bookingId}/cancel": {
            "post": {
                "operationId": "BookingsController_cancelBooking",
                "summary": "Cancel a booking (customer)",
                "parameters": [
                    {
                        "name": "bookingId",
                        "required": true,
                        "in": "path",
                        "schema": {
                            "format": "uuid",
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/CancelBookingDto"
